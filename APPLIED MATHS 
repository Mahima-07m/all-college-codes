        "# ============================================================\n",
        "# ECG SIGNAL ANALYSIS USING FFT & WAVELET TRANSFORM\n",
        "# ============================================================\n",
        "\n",
        "# Install required libraries\n",
        "!pip install wfdb pywavelets\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# IMPORT LIBRARIES\n",
        "# ------------------------------------------------------------\n",
        "import wfdb\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pywt\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# LOAD ECG SIGNAL FROM MIT-BIH DATABASE\n",
        "# ------------------------------------------------------------\n",
        "# Record 100 from MIT-BIH Arrhythmia Database\n",
        "record = wfdb.rdrecord('100', sampto=2000, pn_dir='mitdb')\n",
        "\n",
        "# Use first ECG channel\n",
        "ecg_signal = record.p_signal[:, 0]\n",
        "\n",
        "# Sampling frequency\n",
        "fs = record.fs\n",
        "\n",
        "# Create time axis\n",
        "time = np.arange(len(ecg_signal)) / fs\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# PLOT RAW ECG SIGNAL\n",
        "# ------------------------------------------------------------\n",
        "plt.figure(figsize=(12,4))\n",
        "plt.plot(time, ecg_signal)\n",
        "\n",
        "plt.title(\"Raw ECG Signal\")\n",
        "plt.xlabel(\"Time (seconds)\")\n",
        "plt.ylabel(\"Amplitude (mV)\")\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# FOURIER TRANSFORM (FFT)\n",
        "# ============================================================\n",
        "\n",
        "# Number of samples\n",
        "N = len(ecg_signal)\n",
        "\n",
        "# Compute FFT\n",
        "fft_values = np.fft.fft(ecg_signal)\n",
        "\n",
        "# Frequency axis\n",
        "frequencies = np.fft.fftfreq(N, d=1/fs)\n",
        "\n",
        "# Magnitude spectrum\n",
        "magnitude = np.abs(fft_values)\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# PLOT FFT OUTPUT\n",
        "# ------------------------------------------------------------\n",
        "plt.figure(figsize=(12,4))\n",
        "\n",
        "# Plot only positive frequencies\n",
        "plt.plot(frequencies[:N//2], magnitude[:N//2])\n",
        "\n",
        "plt.title(\"FFT of ECG Signal\")\n",
        "plt.xlabel(\"Frequency (Hz)\")\n",
        "plt.ylabel(\"Magnitude\")\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# WAVELET TRANSFORM\n",
        "# ============================================================\n",
        "\n",
        "# Perform Discrete Wavelet Transform\n",
        "coeffs = pywt.wavedec(ecg_signal, 'db4', level=5)\n",
        "\n",
        "# Extract coefficients\n",
        "cA5, cD5, cD4, cD3, cD2, cD1 = coeffs\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# PLOT WAVELET COMPONENTS\n",
        "# ------------------------------------------------------------\n",
        "plt.figure(figsize=(12,8))\n",
        "\n",
        "# Approximation coefficients\n",
        "plt.subplot(3,1,1)\n",
        "plt.plot(cA5)\n",
        "plt.title(\"Approximation Coefficients (A5)\")\n",
        "\n",
        "# Detail coefficients D3\n",
        "plt.subplot(3,1,2)\n",
        "plt.plot(cD3)\n",
        "plt.title(\"Detail Coefficients (D3)\")\n",
        "\n",
        "# Detail coefficients D4\n",
        "plt.subplot(3,1,3)\n",
        "plt.plot(cD4)\n",
        "plt.title(\"Detail Coefficients (D4) - QRS Dominant\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# SIMPLE HEART RATE CALCULATION\n",
        "# ============================================================\n",
        "\n",
        "# Find R-peaks manually using threshold\n",
        "threshold = np.max(ecg_signal) * 0.6\n",
        "\n",
        "r_peaks = []\n",
        "\n",
        "for i in range(1, len(ecg_signal)-1):\n",
        "\n",
        "    if (\n",
        "        ecg_signal[i] > threshold and\n",
        "        ecg_signal[i] > ecg_signal[i-1] and\n",
        "        ecg_signal[i] > ecg_signal[i+1]\n",
        "    ):\n",
        "        r_peaks.append(i)\n",
        "\n",
        "# Convert sample positions to time\n",
        "r_peak_times = np.array(r_peaks) / fs\n",
        "\n",
        "# RR intervals\n",
        "rr_intervals = np.diff(r_peak_times)\n",
        "\n",
        "# Average heart rate\n",
        "heart_rate = 60 / np.mean(rr_intervals)\n",
        "\n",
        "print(\"Estimated Heart Rate:\", round(heart_rate, 2), \"BPM\")\n",
        "\n",
        "# ============================================================\n",
        "# PLOT ECG WITH R-PEAKS\n",
        "# ============================================================\n",
        "\n",
        "plt.figure(figsize=(12,4))\n",
        "\n",
        "plt.plot(time, ecg_signal, label=\"ECG Signal\")\n",
        "\n",
        "plt.scatter(\n",
        "    r_peak_times,\n",
        "    ecg_signal[r_peaks],\n",
        "    color='red',\n",
        "    label='R Peaks'\n",
        ")\n",
        "\n",
        "plt.title(\"ECG Signal with Detected R-Peaks\")\n",
        "plt.xlabel(\"Time (seconds)\")\n",
        "plt.ylabel(\"Amplitude (mV)\")\n",
        "\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# END OF PROJECT\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\nECG Signal Analysis Completed Successfully!\")"
      ]
